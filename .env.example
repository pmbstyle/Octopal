# TELEGRAM
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram chat IDs allowed to interact with the queen
ALLOWED_TELEGRAM_CHAT_IDS=
BROODMIND_TELEGRAM_PARSE_MODE=MarkdownV2
BROODMIND_HEARTBEAT_INTERVAL_SECONDS=900

# LLM PROVIDER SELECTION
BROODMIND_LLM_PROVIDER=litellm

# OPENROUTER
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_TIMEOUT=120

# LITELLM + Z.AI
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_CHAT_PATH=/chat/completions
ZAI_TIMEOUT_SECONDS=45
ZAI_CONNECT_TIMEOUT_SECONDS=15
ZAI_ACCEPT_LANGUAGE=en-US,en
ZAI_MODEL=glm-5
LITELLM_NUM_RETRIES=3
LITELLM_TIMEOUT=120
LITELLM_FALLBACKS=
LITELLM_DROP_PARAMS=1
LITELLM_CACHING=0
LITELLM_MAX_CONCURRENCY=2
LITELLM_RATE_LIMIT_MAX_RETRIES=6
LITELLM_RATE_LIMIT_BASE_DELAY_SECONDS=1.0
LITELLM_RATE_LIMIT_MAX_DELAY_SECONDS=30.0

# EMBEDDINGS (SEMANTIC MEMORY)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small

# TOOLS
BRAVE_API_KEY=
FIRECRAWL_API_KEY=

# RUNTIME
BROODMIND_STATE_DIR=./data
BROODMIND_WORKSPACE_DIR=./workspace
BROODMIND_LOG_LEVEL=INFO
BROODMIND_DEBUG_PROMPTS=0

# MEMORY
BROODMIND_MEMORY_TOP_K=5
BROODMIND_MEMORY_PREFILTER_K=80
BROODMIND_MEMORY_MIN_SCORE=0.25
BROODMIND_MEMORY_MAX_CHARS=2000
BROODMIND_MEMORY_OWNER_ID=default

# GATEWAY / DASHBOARD
BROODMIND_GATEWAY_HOST=0.0.0.0
BROODMIND_GATEWAY_PORT=8000
BROODMIND_TAILSCALE_IPS=
BROODMIND_DASHBOARD_TOKEN=
BROODMIND_TAILSCALE_AUTO_SERVE=1

# WORKER LAUNCHER
BROODMIND_WORKER_LAUNCHER=same_env
BROODMIND_WORKER_DOCKER_IMAGE=broodmind-worker:latest
BROODMIND_WORKER_DOCKER_WORKSPACE=/workspace
BROODMIND_WORKER_DOCKER_HOST_WORKSPACE=
BROODMIND_WORKER_MAX_SPAWN_DEPTH=2
BROODMIND_WORKER_MAX_CHILDREN_TOTAL=20
BROODMIND_WORKER_MAX_CHILDREN_CONCURRENT=10
BROODMIND_TOOL_LOOP_WARNING_THRESHOLD=8
BROODMIND_TOOL_LOOP_CRITICAL_THRESHOLD=12
BROODMIND_TOOL_LOOP_GLOBAL_BREAKER_THRESHOLD=30
